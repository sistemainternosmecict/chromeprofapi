# Configuração do Banco de Dados
# Copie este arquivo para .env e configure conforme necessário

# SQLite (padrão - desenvolvimento)
DATABASE_URL=sqlite:///./data/chromebook.db

# PostgreSQL (produção)
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/chromebook_db

# MySQL (alternativa)
# DATABASE_URL=mysql+pymysql://usuario:senha@localhost:3306/chromebook_db
